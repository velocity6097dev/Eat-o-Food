.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-top:0.5px solid var(--border)}
.toggle-row:first-of-type{border-top:none}
.toggle-label{font-size:13px;color:var(--text-secondary)}
.toggle-sub{font-size:11px;color:var(--text-muted);margin-top:1px}
.toggle{width:36px;height:20px;border-radius:10px;background:#e85d2f;cursor:pointer;position:relative;flex-shrink:0}
.toggle::after{content:'';position:absolute;width:16px;height:16px;border-radius:50%;background:#fff;top:2px;right:2px;transition:all .2s}
.toggle.off{background:var(--border-strong)}
.toggle.off::after{right:auto;left:2px}

/* promo codes owner */
.promo-code-item{display:flex;align-items:center;gap:10px;background:var(--surface-2);border:0.5px solid var(--border);border-radius:10px;padding:10px;margin-bottom:8px}
.promo-code-badge{font-size:12px;font-weight:500;background:#FAEEDA;color:#633806;padding:4px 10px;border-radius:8px;letter-spacing:.05em;font-family:var(--font-mono)}
.promo-code-info{flex:1;min-width:0}
.promo-code-name{font-size:12px;font-weight:500;color:var(--text-primary)}
.promo-code-meta{font-size:11px;color:var(--text-muted);margin-top:2px}
.promo-active{width:8px;height:8px;border-radius:50%;background:#3B6D11;flex-shrink:0}
.promo-inactive{width:8px;height:8px;border-radius:50%;background:var(--border-strong);flex-shrink:0}
.add-promo-btn{width:100%;padding:10px;background:var(--surface-1);border:1px dashed var(--border-strong);border-radius:10px;font-size:13px;color:#e85d2f;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px}

.btn-primary{width:100%;padding:13px;background:#e85d2f;color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:500;cursor:pointer;margin-top:10px}
.btn-secondary{width:100%;padding:12px;background:var(--surface-2);color:#e85d2f;border:0.5px solid #e85d2f;border-radius:12px;font-size:14px;cursor:pointer;margin-top:8px}

.screen-title{font-size:11px;color:var(--text-muted);text-align:center;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.screen-title::before,.screen-title::after{content:'';flex:1;height:0.5px;background:var(--border)}
</style>

