/* section head */
.sec-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.sec-head h3{font-size:14px;font-weight:500;color:var(--text-primary)}
.sec-head a{font-size:12px;color:#e85d2f;cursor:pointer}

/* cart bar */
.cart-bar{background:#e85d2f;border-radius:12px;padding:12px 14px;display:flex;align-items:center;margin-bottom:12px}
.cart-bar .cb-info{flex:1;color:#fff}
.cart-bar .cb-count{font-size:12px;opacity:.85}
.cart-bar .cb-total{font-size:15px;font-weight:500}
.cart-bar .cb-btn{background:rgba(255,255,255,0.2);color:#fff;border:none;border-radius:8px;padding:7px 14px;font-size:12px;font-weight:500;cursor:pointer}

/* cart list */
.cart-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:0.5px solid var(--border)}
.cart-item:last-child{border-bottom:none}
.ci-name{flex:1;font-size:13px;color:var(--text-primary)}
.ci-price{font-size:13px;font-weight:500;color:var(--text-primary);margin-right:8px}

/* promo row */
.promo-row{display:flex;gap:8px;margin-bottom:12px;align-items:center}
.promo-input{flex:1;height:38px;border:0.5px solid var(--border);border-radius:var(--radius);padding:0 10px;font-size:13px;background:var(--surface-2);color:var(--text-primary)}
.promo-apply{height:38px;padding:0 14px;background:#e85d2f;color:#fff;border:none;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap}
.promo-success{background:#EAF3DE;border:0.5px solid #C0DD97;border-radius:var(--radius);padding:8px 12px;display:flex;align-items:center;gap:8px;margin-bottom:10px}
.promo-success span{font-size:12px;color:#3B6D11;flex:1}
.promo-remove{font-size:11px;color:#A32D2D;cursor:pointer}

/* bill */
.bill-row{display:flex;justify-content:space-between;padding:5px 0;font-size:13px;color:var(--text-secondary)}
.bill-row.total{font-size:15px;font-weight:500;color:var(--text-primary);border-top:0.5px solid var(--border);padding-top:10px;margin-top:4px}
.bill-row.savings{color:#3B6D11}
.bill-row.tax{color:var(--text-muted);font-size:12px}

/* gift section */
.gift-card{background:#EEEDFE;border:0.5px solid #AFA9EC;border-radius:12px;padding:12px;margin-bottom:12px}
.gift-card h4{font-size:13px;font-weight:500;color:#3C3489;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.gift-subtitle{font-size:11px;color:#534AB7;margin-bottom:10px;line-height:1.5}
.gift-form{display:flex;flex-direction:column;gap:8px}
.gift-row{display:flex;gap:8px}
.gift-select{flex:1;height:36px;border:0.5px solid #AFA9EC;border-radius:var(--radius);padding:0 8px;font-size:12px;background:#fff;color:#3C3489}
.gift-input{flex:1;height:36px;border:0.5px solid #AFA9EC;border-radius:var(--radius);padding:0 8px;font-size:12px;background:#fff;color:var(--text-primary)}
.gift-input::placeholder{color:var(--text-muted)}
.gift-send{width:100%;padding:9px;background:#534AB7;color:#fff;border:none;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;margin-top:4px}
.gift-sent{display:flex;align-items:center;gap:8px;background:#EAF3DE;border-radius:8px;padding:8px;margin-top:6px}
.gift-sent span{font-size:12px;color:#3B6D11}

/* pay methods */
.pay-method{display:flex;align-items:center;gap:10px;background:var(--surface-2);border:0.5px solid var(--border);border-radius:10px;padding:10px;margin-bottom:8px;cursor:pointer}
.pay-method.sel{border:1.5px solid #e85d2f;background:#fff4f0}
.pay-icon{width:36px;height:36px;border-radius:8px;background:var(--surface-1);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.pay-name{font-size:13px;font-weight:500;color:var(--text-primary)}
.pay-sub{font-size:11px;color:var(--text-muted);margin-top:1px}
.radio{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--border-strong);margin-left:auto;flex-shrink:0;position:relative}
.radio.sel{border-color:#e85d2f}
.radio.sel::after{content:'';position:absolute;width:8px;height:8px;border-radius:50%;background:#e85d2f;top:3px;left:3px}

/* success */
.success-wrap{text-align:center;padding:20px 0 12px}
.success-circle{width:64px;height:64px;border-radius:50%;background:#EAF3DE;margin:0 auto 12px;display:flex;align-items:center;justify-content:center}
.success-circle i{font-size:28px;color:#3B6D11}
.success-wrap h2{font-size:17px;font-weight:500;color:var(--text-primary)}
.success-wrap p{font-size:13px;color:var(--text-muted);margin-top:6px;line-height:1.6}
.order-id{font-size:12px;color:#e85d2f;background:#fff4f0;padding:4px 12px;border-radius:20px;display:inline-block;margin-top:8px}

/* tracker */
.tracker{background:var(--surface-2);border:0.5px solid var(--border);border-radius:12px;padding:12px;margin-top:14px}
.tracker h4{font-size:13px;font-weight:500;color:var(--text-primary);margin-bottom:12px}
.track-step{display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;position:relative}
.track-step:last-child{margin-bottom:0}
.step-circle{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.step-circle.done{background:#EAF3DE}
.step-circle.done i{font-size:12px;color:#3B6D11}
.step-circle.active{background:#FAEEDA}
.step-circle.active i{font-size:12px;color:#633806}
.step-circle.pending{background:var(--surface-1);border:0.5px solid var(--border)}
.step-circle.pending i{font-size:12px;color:var(--text-muted)}
.step-text{flex:1}
.step-label{font-size:13px;color:var(--text-primary)}
.step-label.active{font-weight:500}
.step-sub{font-size:11px;color:var(--text-muted);margin-top:2px}
.step-line{position:absolute;left:11px;top:26px;width:1.5px;height:20px;background:var(--border)}

/* gift notification */
.gift-notif{background:#EEEDFE;border:0.5px solid #AFA9EC;border-radius:12px;padding:12px;margin-bottom:12px;display:flex;gap:10px;align-items:flex-start}
.gift-notif-icon{width:36px;height:36px;border-radius:50%;background:#534AB7;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.gift-notif-icon i{font-size:18px;color:#fff}
.gift-notif-text h4{font-size:13px;font-weight:500;color:#3C3489}
.gift-notif-text p{font-size:12px;color:#534AB7;margin-top:3px;line-height:1.5}
.gift-notif-text .gn-from{font-size:11px;color:#534AB7;margin-top:6px;background:rgba(83,74,183,0.1);padding:3px 8px;border-radius:8px;display:inline-block}

/* owner screens */
.metric-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.metric{background:var(--surface-2);border:0.5px solid var(--border);border-radius:12px;padding:12px}
.metric-label{font-size:11px;color:var(--text-muted);margin-bottom:4px}
.metric-value{font-size:20px;font-weight:500;color:var(--text-primary)}
.metric-delta{font-size:11px;margin-top:2px}
.delta-up{color:#3B6D11}
.delta-dn{color:#A32D2D}

.table-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.tbl-card{background:var(--surface-2);border:0.5px solid var(--border);border-radius:10px;padding:10px}
.tbl-card.occ{border-color:#e85d2f40;background:#fff4f0}
.tbl-card.rsv{border-color:#534AB740;background:#EEEDFE}
.tbl-card.avl{border-color:#3B6D1140;background:#EAF3DE}
.tbl-card.gift{border-color:#534AB740;background:#EEEDFE}
.tbl-num{font-size:15px;font-weight:500;color:var(--text-primary)}
.tbl-seats{font-size:11px;color:var(--text-muted);margin-top:1px}
.tbl-status{font-size:10px;padding:2px 6px;border-radius:8px;margin-top:6px;display:inline-block}
.tbl-status.occ{background:#fde8df;color:#c94820}
.tbl-status.rsv{background:#EEEDFE;color:#3C3489}
