.tbl-btn.purple{background:#EEEDFE;border-color:#AFA9EC;color:#3C3489}
.tbl-btn.green{background:#EAF3DE;border-color:#C0DD97;color:#3B6D11}

.order-card{background:var(--surface-2);border:0.5px solid var(--border);border-radius:10px;padding:10px;margin-bottom:8px}
