.food-name{font-size:13px;font-weight:500;color:var(--text-primary)}
.food-desc{font-size:11px;color:var(--text-muted);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.food-price{font-size:13px;font-weight:500;color:var(--text-primary);margin-top:3px}
.food-avail-time{font-size:10px;color:#633806;background:#FAEEDA;padding:2px 6px;border-radius:10px;margin-top:3px;display:inline-block}
